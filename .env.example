# stealth-trader — env template
# Copy to .env and fill in. Run `pnpm setup` to be walked through it.

# --- Telegram (required for the bot; not needed for `pnpm smoke`) ---
# Get one from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=

# Telegram user IDs allowed to use the bot. Comma-separated.
# Get yours from @userinfobot.
AUTHORIZED_TG_USERS=

# --- Solana RPC (required) ---
# Helius free tier works (https://dev.helius.dev). Public RPC will rate-limit.
HELIUS_RPC_URL=

# Helius webhook auth header — any random string, you set it once.
# Generated by `pnpm setup` if empty.
HELIUS_WEBHOOK_SECRET=

# Public URL the bot listens on for Helius webhooks (e.g. ngrok or your host).
# Required only if you're using webhook copy-trade mode (default).
WEBHOOK_PUBLIC_URL=

# --- Database (optional) ---
# Leave blank for zero-Docker default (pglite at ~/.stealth-trader/db).
# Use `postgresql://…` to point at a real Postgres cluster.
# Use `pglite:/abs/path` for a custom pglite location.
DATABASE_URL=

# --- Root of trust (required) ---
# 32 bytes hex (64 chars). Derives every Telegram user's Solana keypair.
# Generate once with: openssl rand -hex 32
# LOSE THIS = LOSE EVERY USER'S FUNDS. Store offline.
MASTER_SEED=

# --- b402 cluster (default: mainnet) ---
B402_CLUSTER=mainnet

# Path to a Solana keypair file. Default: ~/.config/solana/id.json
# If unset, the bot reads the default Solana CLI keypair.
SOLANA_KEYPAIR_PATH=

# --- Optional ---
# Fee-payer keypair (Solana CLI JSON format) used to absorb one-time
# recipient ATA rent (~0.002 SOL per address/mint pair) on /cashout.
# Without this, fresh-recipient cashouts only work if the user's derived
# keypair has spare SOL. Recommended for any deployment serving real users.
OPERATOR_FEE_KEYPAIR_PATH=

# Override the hosted b402 relayer (default: mainnet hosted endpoint).
# Run your own from b402-ai/b402-solana packages/relayer.
B402_RELAYER_URL=

# Per-user log level (debug | info | warn | error). Default: info.
LOG_LEVEL=info
