# stealth-trader — env template
# Copy to .env and fill in. Run `pnpm setup` to be walked through it.

# --- Telegram (required) ---
# Get one from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=

# Telegram user IDs allowed to use the bot. Comma-separated.
# Get yours from @userinfobot.
AUTHORIZED_TG_USERS=

# --- Solana RPC (required) ---
# Helius free tier works (https://dev.helius.dev). Public RPC will rate-limit.
HELIUS_RPC_URL=

# Helius webhook auth header — any random string, you set it once.
# Generated by `pnpm setup` if empty.
HELIUS_WEBHOOK_SECRET=

# Public URL the bot listens on for Helius webhooks (e.g. ngrok or your host).
# Required only if you're using webhook copy-trade mode (default).
WEBHOOK_PUBLIC_URL=

# --- Database (required) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stealth_trader

# --- b402 cluster (default: mainnet) ---
B402_CLUSTER=mainnet

# Path to a Solana keypair file. Default: ~/.config/solana/id.json
# If unset, the bot reads the default Solana CLI keypair.
SOLANA_KEYPAIR_PATH=

# --- Optional ---
# Override the hosted b402 relayer (default: mainnet hosted endpoint).
# Run your own from b402-ai/b402-solana packages/relayer.
B402_RELAYER_URL=

# Per-user log level (debug | info | warn | error). Default: info.
LOG_LEVEL=info
